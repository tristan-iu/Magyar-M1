# Clé DeepL (moteur principal de traduction)
# Obtenable ici : https://www.deepl.com/fr/your-account/keys
DEEPL_AUTH_KEY=your_deepl_api_key_here

# LM Studio — serveur local OpenAI-compatible (fallback si DeepL indisponible)
# Lancer LM Studio en mode serveur avant d'utiliser ce moteur
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=mistral
OLLAMA_BIN=/usr/local/bin/ollama

# Modèle Google Madlad (optionnel — moteur alternatif non maintenu)
# TRANSLATEGEMMA_MODEL=google/madlad400-3b-mt

# Chemin local vers les fiches (surcharge paths.fiches_dir dans config.yaml)
# FICHES_DIR=/path/to/M1_corpus/processed/fiches
