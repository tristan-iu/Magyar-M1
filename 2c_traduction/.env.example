# Clé DeepL (moteur principal de traduction)
# Obtenable ici : https://www.deepl.com/fr/your-account/keys
DEEPL_AUTH_KEY=your_deepl_api_key_here

# ── Fallback local (si DEEPL_AUTH_KEY absent) ───────────────────────────────
# Le moteur "lmstudio" parle à n'importe quel serveur local OpenAI-compatible
# via ces variables. Laisser commenté pour garder les valeurs par défaut.
#   - LM Studio (mode serveur) : http://127.0.0.1:1234/v1
#   - Ollama (ollama serve)    : http://127.0.0.1:11434/v1
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
# LMSTUDIO_API_KEY=lm-studio
# LMSTUDIO_MODEL=                 # vide = premier modèle chargé sur le serveur

# Le dossier des fiches est lu depuis 0_config/config.yaml (paths.fiches_dir)
# ou via l'option CLI --fiches-dir.
